# ============================================================
# GiraChavePro Worker — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://irwqneemfyzlicbxvhfl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Gemini (Virtual Staging) ─────────────────────────
GOOGLE_VS_API_KEY=
# Fallback se GOOGLE_VS_API_KEY não estiver definida
GOOGLE_GENERATIVE_AI_API_KEY=
# Modelo de geração de imagem — migração obrigatória para gemini-3.1-pro-preview
VS_MODEL_ID=gemini-3.1-pro-preview

# ── Replicate (Foto Turbinada) ───────────────────────────────
REPLICATE_API_TOKEN=
FT_MODEL_ID=

# ── Cloudflare R2 (Storage) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Telegram (Alertas Founder) ───────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Resend (Email) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=GiraChavePro <noreply@girachavepro.com>

# ── App ──────────────────────────────────────────────────────
APP_URL=https://www.girachavepro.com
# Porta do servidor Express (anti-sleep health check)
PORT=3001
